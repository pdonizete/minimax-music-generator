# MiniMax Music Generator — variáveis de ambiente
# Copie este arquivo para `.env` e preencha com seus valores reais.

# Token do plano Token Plan contratado em https://api.minimax.io
# Variável esperada pelo cliente HTTP: MINIMAX_API_KEY
token_minimax=sk-cp-substitua-pelo-seu-token-aqui

# URL base da API (plano global / Token Plan)
MINIMAX_BASE_URL=https://api.minimax.io

# Endpoint de geração de música (caminho relativo à base)
# Padrão do music-3.0: /v1/music_generation
MINIMAX_MUSIC_ENDPOINT=/v1/music_generation

# Modelo a ser utilizado
# Opções: music-3.0 (recomendado, Token Plan), music-2.6
MINIMAX_MUSIC_MODEL=music-3.0

# Modelo de texto usado para gerar letras roteiradas (com [Verse]/[Chorus]/[Bridge])
# quando o Mavis tem que gerar a letra sozinho. Padrão: MiniMax-M3.
MINIMAX_TEXT_MODEL=MiniMax-M3

# Diretório padrão onde as músicas geradas serão salvas.
# Se vazio, será usado ~/Music/minimax-music.
# Você também pode alterar isto pela tela de Configurações do app.
MINIMAX_OUTPUT_DIR=
